<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    tools:context=".MapActivity">

    <androidx.cardview.widget.CardView
        android:id="@+id/mapCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toTopOf="@+id/btnConfirmLocation"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/map"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </androidx.cardview.widget.CardView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabCurrentLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="32dp"
        android:contentDescription="@string/desc_current_location"
        app:backgroundTint="@color/accent"
        app:layout_constraintBottom_toBottomOf="@id/mapCard"
        app:layout_constraintEnd_toEndOf="@id/mapCard"
        app:srcCompat="@android:drawable/ic_menu_mylocation"
        app:tint="@color/black" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmLocation"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_margin="16dp"
        android:text="@string/btn_confirm_location"
        android:textAllCaps="false"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/accent"
        app:cornerRadius="30dp"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ProgressBar
        android:id="@+id/mapProgressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="@color/accent"
        app:layout_constraintTop_toTopOf="@id/mapCard"
        app:layout_constraintBottom_toBottomOf="@id/mapCard"
        app:layout_constraintStart_toStartOf="@id/mapCard"
        app:layout_constraintEnd_toEndOf="@id/mapCard" />

</androidx.constraintlayout.widget.ConstraintLayout>