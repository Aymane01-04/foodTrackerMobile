<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.FoodTracker_ayman" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Main theme colors -->
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
    </style>

    <style name="Theme.FoodTracker_ayman" parent="Base.Theme.FoodTracker_ayman">
        <!-- Style for Cards in Cal AI style -->
        <item name="materialCardViewStyle">@style/Widget.App.CardView</item>
    </style>

    <style name="Widget.App.CardView" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.App.MediumComponent</item>
    </style>

    <style name="ShapeAppearance.App.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">24dp</item>
    </style>
</resources>